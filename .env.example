# Stock Analytics Pipeline — Environment Variables
# Copy to .env and fill in your values.

# Comma-separated ticker symbols (single source of truth for watchlist)
USER_STOCK_WATCH_LIST=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,BRK-B,JPM,V,JNJ,WMT,PG,MA,HD,XOM,UNH,BAC,PFE,ABBV

# Databricks workspace (for CLI auth)
DATABRICKS_HOST=https://YOUR_WORKSPACE.cloud.databricks.com
DATABRICKS_TOKEN=your_personal_access_token_here